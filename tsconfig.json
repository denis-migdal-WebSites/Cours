{
    "extends": "./build/WebpackFramework/files/tsconfig.json",

    "include": ["./src"],

    "compilerOptions": {

        "rootDir": ".",
        "outDir": "./build/TS",

        "paths": {
            "MWL@2026:*"     : ["./libs/MWL@2026/src/*"],
            "TPEngine@2026:*": ["./libs/MWL@2026/src/TPEngine/*"],
            "@LISS/*"     : ["./libs/LISS/V3/*"],
            "@TPEngine/*" : [ "./libs/TPEngine/src/*" ],
            "@WebSlides/*": [ "./libs/WebSlides/src/*" ],
            "@sqlite/*"   : [ "./libs/sqlite/*" ],
            "@Cours/*"    : ["./src/*"]
        }
    }
}